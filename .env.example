# 1v1 Club — Environment Variables
# Copy this to .env.local and fill in your values

# Supabase (get from: https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (get from: https://dashboard.stripe.com/apikeys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Canonical public web origin — used to build shareable invite links and
# Stripe redirect URLs. On the iOS app, window.location.origin is
# capacitor://localhost, which isn't a usable link, so this must be set.
VITE_APP_WEB_ORIGIN=https://1v1club.com

# --- Supabase Edge Function Secrets (set via: supabase secrets set KEY=value) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   (from Stripe webhook dashboard)
